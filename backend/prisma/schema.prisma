generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String                   @id @default(cuid())
  name            String
  email           String                   @unique
  password        String?
  avatar          String?
  role            Role                     @default(CUSTOMER)
  provider        AuthProvider             @default(LOCAL)
  isActive        Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  feedbacks       RecommendationFeedback[]
  recommendations Recommendation[]
  profile         UserProfile?

  @@map("users")
}

model UserProfile {
  id               String      @id @default(cuid())
  userId           String      @unique
  gender           Gender
  age              Int
  height           Float
  weight           Float
  skinTone         SkinTone
  budgetRange      BudgetRange
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  favoriteColorId  String
  preferredStyleId String
  favoriteColor    Color       @relation(fields: [favoriteColorId], references: [id])
  preferredStyle   Style       @relation(fields: [preferredStyleId], references: [id])
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Style {
  id           String        @id @default(cuid())
  name         String        @unique
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  fashionItems FashionItem[]
  outfits      Outfit[]
  userProfiles UserProfile[]

  @@map("styles")
}

model Color {
  id           String        @id @default(cuid())
  name         String        @unique
  hexCode      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  fashionItems FashionItem[]
  userProfiles UserProfile[]

  @@map("colors")
}

model Category {
  id           String        @id @default(cuid())
  name         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  fashionItems FashionItem[]

  @@map("categories")
}

model Occasion {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  outfits     Outfit[]

  @@map("occasions")
}

model BodyType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  outfits     Outfit[]

  @@map("body_types")
}

model FashionItem {
  id          String       @id @default(cuid())
  name        String
  description String?
  gender      Gender
  price       Decimal      @db.Decimal(12, 2)
  imageUrl    String?
  categoryId  String
  styleId     String
  colorId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  isActive    Boolean      @default(true)
  slug        String       @unique
  category    Category     @relation(fields: [categoryId], references: [id])
  color       Color        @relation(fields: [colorId], references: [id])
  style       Style        @relation(fields: [styleId], references: [id])
  outfitItems OutfitItem[]

  @@map("fashion_items")
}

model Outfit {
  id                  String               @id @default(cuid())
  name                String
  description         String?
  gender              Gender
  budgetRange         BudgetRange
  imageUrl            String?
  styleId             String
  occasionId          String
  bodyTypeId          String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  isActive            Boolean              @default(true)
  slug                String               @unique
  outfitItems         OutfitItem[]
  bodyType            BodyType             @relation(fields: [bodyTypeId], references: [id])
  occasion            Occasion             @relation(fields: [occasionId], references: [id])
  style               Style                @relation(fields: [styleId], references: [id])
  recommendationItems RecommendationItem[]

  @@map("outfits")
}

model OutfitItem {
  id            String         @id @default(cuid())
  role          OutfitItemRole
  outfitId      String
  fashionItemId String
  createdAt     DateTime       @default(now())
  fashionItem   FashionItem    @relation(fields: [fashionItemId], references: [id])
  outfit        Outfit         @relation(fields: [outfitId], references: [id], onDelete: Cascade)

  @@unique([outfitId, role])
  @@map("outfit_items")
}

model Recommendation {
  id          String               @id @default(cuid())
  userId      String
  createdAt   DateTime             @default(now())
  bmi         Float?
  bodyType    String?
  generatedAt DateTime             @default(now())
  items       RecommendationItem[]
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recommendations")
}

model RecommendationItem {
  id               String                   @id @default(cuid())
  recommendationId String
  outfitId         String
  score            Int
  createdAt        DateTime                 @default(now())
  reasons          Json?
  aiResult         RecommendationAiResult?
  feedbacks        RecommendationFeedback[]
  outfit           Outfit                   @relation(fields: [outfitId], references: [id])
  recommendation   Recommendation           @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@map("recommendation_items")
}

model RecommendationFeedback {
  id                   String             @id @default(cuid())
  userId               String
  recommendationItemId String
  feedback             FeedbackType
  createdAt            DateTime           @default(now())
  recommendationItem   RecommendationItem @relation(fields: [recommendationItemId], references: [id], onDelete: Cascade)
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recommendationItemId])
  @@map("recommendation_feedbacks")
}

model RecommendationAiResult {
  id                   String             @id @default(cuid())
  recommendationItemId String             @unique
  advice               String
  explanation          String
  imageUrl             String?
  modelPrompt          String?
  outfitPrompt         String?
  finalPrompt          String?
  createdAt            DateTime           @default(now())
  recommendationItem   RecommendationItem @relation(fields: [recommendationItemId], references: [id], onDelete: Cascade)

  @@map("recommendation_ai_results")
}

enum Role {
  USER
  ADMIN
  CUSTOMER
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum Gender {
  MALE
  FEMALE
}

enum SkinTone {
  FAIR
  LIGHT
  MEDIUM
  TAN
  DEEP
}

enum BudgetRange {
  LESS_THAN_250K
  BETWEEN_250K_500K
  BETWEEN_500K_1M
  ABOVE_1M
}

enum OutfitItemRole {
  TOP
  BOTTOM
  OUTER
  FOOTWEAR
  ACCESSORY
}

enum FeedbackType {
  LIKE
  NEUTRAL
  DISLIKE
}
